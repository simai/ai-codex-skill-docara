{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://simai.io/schemas/graph/growgraph-adoption-registry.schema.json",
  "title": "GrowGraph Adoption Registry",
  "description": "Dashboard registry of GrowGraph adoption state across skills, projects or federation targets.",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "operation_id",
    "created_at",
    "target_scope",
    "expected_target_refs",
    "targets",
    "summary",
    "next_actions",
    "canonical_write_allowed"
  ],
  "properties": {
    "schema_version": { "type": "string", "minLength": 1 },
    "id": { "type": "string", "minLength": 1 },
    "operation_id": { "type": "string", "const": "growgraph.adoption-registry" },
    "created_at": { "type": "string", "minLength": 1 },
    "target_scope": { "type": "string", "minLength": 1 },
    "expected_target_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "targets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "target_ref",
          "owner_skill",
          "adoption_level",
          "adoption_level_name",
          "status_summary",
          "report_ref",
          "blockers"
        ],
        "properties": {
          "target_ref": { "type": "string", "minLength": 1 },
          "owner_skill": { "type": ["string", "null"] },
          "adoption_level": { "type": "integer", "minimum": 0, "maximum": 10 },
          "adoption_level_name": {
            "type": "string",
            "enum": [
              "not_started",
              "inventoried",
              "seeded",
              "embryo_reviewable",
              "scored",
              "proposal_gated",
              "semantically_preserved",
              "effectiveness_checked",
              "federation_ready",
              "federation_integrated",
              "graph_first_source_candidate"
            ]
          },
          "status_summary": { "type": "object" },
          "report_ref": { "type": ["string", "null"] },
          "blockers": { "type": "array" }
        },
        "additionalProperties": true
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "target_count",
        "gga9_count",
        "blocked_count",
        "average_adoption_level",
        "missing_target_count"
      ],
      "properties": {
        "target_count": { "type": "integer", "minimum": 0 },
        "gga9_count": { "type": "integer", "minimum": 0 },
        "blocked_count": { "type": "integer", "minimum": 0 },
        "average_adoption_level": { "type": "number", "minimum": 0, "maximum": 10 },
        "missing_target_count": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "next_actions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "canonical_write_allowed": { "const": false }
  },
  "additionalProperties": true
}
