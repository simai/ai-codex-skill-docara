{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://simai.io/schemas/graph/skill-map.schema.json",
  "title": "SkillMap",
  "type": "object",
  "required": [
    "schema_version",
    "operation_id",
    "created_at",
    "skill_root",
    "skill_name",
    "item_count",
    "items",
    "canonical_write_allowed"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "operation_id": { "const": "graph.skill.import" },
    "created_at": { "type": "string" },
    "skill_root": { "type": "string" },
    "skill_name": { "type": "string" },
    "item_count": { "type": "integer", "minimum": 0 },
    "by_kind": { "type": "object", "additionalProperties": true },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["item_id", "kind", "title", "path", "sha256"],
        "properties": {
          "item_id": { "type": "string" },
          "kind": { "type": "string" },
          "title": { "type": "string" },
          "path": { "type": "string" },
          "skill_path": { "type": "string" },
          "sha256": { "type": "string" },
          "summary": { "type": "string" },
          "text_excerpt": { "type": "string" },
          "source_type": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "canonical_write_allowed": { "const": false }
  },
  "additionalProperties": true
}
