{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://simai.io/schemas/graph/core-relation.schema.json",
  "title": "Graph Relation Object",
  "type": "object",
  "required": [
    "id",
    "schema_version",
    "kind",
    "from",
    "to",
    "relation_type",
    "status",
    "source_refs"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "schema_version": {
      "type": "string"
    },
    "kind": {
      "const": "relation"
    },
    "from": {
      "type": "string"
    },
    "to": {
      "type": "string"
    },
    "relation_type": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "evidence_status": {
      "type": "string",
      "enum": [
        "asserted_by_human",
        "extracted_by_ai",
        "validated",
        "disputed",
        "obsolete",
        "superseded"
      ]
    },
    "impact": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
