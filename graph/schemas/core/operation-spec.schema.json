{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://simai.io/schemas/graph/operation-spec.schema.json",
  "title": "OperationSpec",
  "type": "object",
  "required": [
    "id",
    "schema_version",
    "operation_object_id",
    "title",
    "default_mode",
    "cost_class",
    "changes",
    "requires_dry_run",
    "requires_approval",
    "input_contract",
    "output_contract",
    "result_contract_ref",
    "retention_class",
    "source_refs"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "operation_object_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string"
    },
    "default_mode": {
      "type": "string",
      "enum": [
        "read_only",
        "suggest",
        "draft",
        "write_generated",
        "write_canonical",
        "execute_safe",
        "requires_approval"
      ]
    },
    "cost_class": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "destructive",
        "privacy_sensitive",
        "human_impacting"
      ]
    },
    "changes": {
      "type": "string",
      "enum": [
        "none",
        "generated",
        "canonical",
        "external"
      ]
    },
    "requires_dry_run": {
      "type": "boolean"
    },
    "requires_approval": {
      "type": "boolean"
    },
    "approval_policy": {
      "type": "string"
    },
    "input_contract": {
      "$ref": "#/$defs/contract"
    },
    "output_contract": {
      "$ref": "#/$defs/contract"
    },
    "canonical_write_policy": {
      "type": "string"
    },
    "generated_write_policy": {
      "type": "string"
    },
    "result_contract_ref": {
      "type": "string",
      "minLength": 1
    },
    "rollback_policy": {
      "type": "string"
    },
    "retention_class": {
      "type": "string",
      "minLength": 1
    },
    "safety_gates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_suggested_operations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "contract": {
      "type": "object",
      "required": [
        "required",
        "optional"
      ],
      "properties": {
        "required": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "optional": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
