{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://simai.io/schemas/graph/query-budget.schema.json",
  "title": "QueryBudget",
  "type": "object",
  "required": [
    "token_budget",
    "time_budget_ms",
    "max_depth",
    "max_objects",
    "min_confidence",
    "min_effective_weight"
  ],
  "properties": {
    "token_budget": {
      "type": "integer",
      "minimum": 1
    },
    "time_budget_ms": {
      "type": "integer",
      "minimum": 1
    },
    "max_depth": {
      "type": "integer",
      "minimum": 0
    },
    "max_objects": {
      "type": "integer",
      "minimum": 1
    },
    "min_confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "min_effective_weight": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "include_disputed": {
      "type": "boolean"
    },
    "include_obsolete": {
      "type": "boolean"
    },
    "include_private": {
      "type": "boolean"
    }
  },
  "additionalProperties": true
}
