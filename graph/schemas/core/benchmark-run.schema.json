{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://simai.io/schemas/graph/benchmark-run.schema.json",
  "title": "BenchmarkRun",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "experiment_id",
    "iteration_id",
    "implementation_id",
    "mode",
    "suite_ref",
    "dataset_ref",
    "protocol_version",
    "record_files",
    "evidence_files",
    "status"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "experiment_id": {
      "type": "string",
      "minLength": 1
    },
    "iteration_id": {
      "type": "string",
      "minLength": 1
    },
    "implementation_id": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "enum": [
        "current",
        "graph"
      ]
    },
    "suite_ref": {
      "type": "string"
    },
    "suite_version": {
      "type": "string"
    },
    "dataset_ref": {
      "type": "string"
    },
    "dataset_version": {
      "type": "string"
    },
    "protocol_version": {
      "type": "string"
    },
    "graph_schema_version": {
      "type": "string"
    },
    "profile_schema_version": {
      "type": "string"
    },
    "kernel_version": {
      "type": "string"
    },
    "runtime_info": {
      "type": "object",
      "additionalProperties": true
    },
    "started_at": {
      "type": "string"
    },
    "finished_at": {
      "type": "string"
    },
    "record_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "computed_metrics_ref": {
      "type": "string"
    },
    "comparison_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "planned",
        "running",
        "completed",
        "partial",
        "failed",
        "invalid"
      ]
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "review_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
