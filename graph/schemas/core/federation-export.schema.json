    },
    "graph_id": {
      "type": "string"
    },
    "exported_at": {
      "type": "string"
    },
    "freshness_hash": {
      "type": "string"
    },
    "manifest": {
      "type": "object"
    },
    "type_descriptor_summary": {
      "type": "object"
    },
    "graph_contracts": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "object_index_summary": {
      "type": "object"
    },
    "relation_endpoint_summary": {
      "type": "object"
    },
    "readiness_summary": {
      "type": "object"
    },
    "evidence_status_summary": {
      "type": "object"
    },
    "unresolved_links": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
