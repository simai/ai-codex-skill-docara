{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://simai.io/schemas/graph/controlled-rollout-decision.schema.json",
  "title": "ControlledRolloutDecision",
  "type": "object",
  "required": [
    "schema_version",
    "operation_id",
    "decision_id",
    "created_at",
    "owner",
    "scope",
    "global_decision",
    "status_legend",
    "skill_decisions",
    "global_rules",
    "evidence_refs",
    "next_actions",
    "canonical_write_allowed"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "operation_id": { "const": "graph.controlled-rollout-decision" },
    "decision_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "owner": { "type": "string", "minLength": 1 },
    "scope": {
      "type": "object",
      "required": ["skills", "mode"],
      "properties": {
        "skills": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "mode": { "type": "string", "minLength": 1 },
        "notes": { "type": "string" }
      },
      "additionalProperties": true
    },
    "global_decision": {
      "type": "string",
      "enum": [
        "graph_first_allowed",
        "controlled_enablement_allowed",
        "review_required",
        "fallback_required",
        "blocked"
      ]
    },
    "status_legend": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "skill_decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "skill",
          "repo",
          "status",
          "selected_profile",
          "scope",
          "fallback_required",
          "runtime_allowed",
          "metrics",
          "evidence_refs",
          "limitations",
          "next_actions"
        ],
        "properties": {
          "skill": { "type": "string", "minLength": 1 },
          "repo": { "type": "string", "minLength": 1 },
          "status": {
            "type": "string",
            "enum": [
              "graph_first_allowed",
              "controlled_enablement_allowed",
              "review_required",
              "fallback_required",
              "blocked"
            ]
          },
          "selected_profile": {
            "type": "string",
            "enum": ["compact", "standard", "broad", "custom", "not_applicable"]
          },
          "scope": { "type": "string", "minLength": 1 },
          "fallback_required": { "type": "boolean" },
          "runtime_allowed": { "type": "boolean" },
          "metrics": {
            "type": "object",
            "required": [
              "baseline_context_bytes",
              "graph_context_bytes",
              "delta_percent",
              "average_context_reduction",
              "comparison_verdict"
            ],
            "properties": {
              "baseline_context_bytes": { "type": ["number", "null"] },
              "graph_context_bytes": { "type": ["number", "null"] },
              "delta_percent": { "type": ["number", "null"] },
              "average_context_reduction": { "type": ["number", "null"] },
              "comparison_verdict": { "type": "string" },
              "scorecard_verdict": { "type": ["string", "null"] },
              "overall_score": { "type": ["number", "null"] }
            },
            "additionalProperties": true
          },
          "evidence_refs": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "limitations": {
            "type": "array",
            "items": { "type": "string" }
          },
          "next_actions": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": true
      }
    },
    "global_rules": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "next_actions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "canonical_write_allowed": { "const": false }
  },
  "additionalProperties": true
}
