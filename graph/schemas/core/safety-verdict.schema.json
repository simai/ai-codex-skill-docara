{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://simai.io/schemas/graph/safety-verdict.schema.json",
  "title": "SafetyVerdict",
  "type": "object",
  "required": [
    "schema_version",
    "action",
    "actor",
    "verdict",
    "policy_reasons"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "action": { "type": "string" },
    "actor": { "type": "string" },
    "verdict": {
      "type": "string",
      "enum": ["allowed", "blocked", "requires_approval", "dry_run_only"]
    },
    "operation_mode": { "type": "string" },
    "cost_class": { "type": "string" },
    "policy_reasons": {
      "type": "array",
      "items": { "type": "string" }
    },
    "required_next_operation": { "type": "string" },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
