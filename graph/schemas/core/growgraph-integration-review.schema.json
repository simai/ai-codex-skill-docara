{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://simai.io/schemas/graph/growgraph-integration-review.schema.json",
  "title": "GrowGraph Integration Review",
  "description": "Generated-only GGA9 review for AGENTS.md and hook/CI integration before federation runtime use.",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "operation_id",
    "created_at",
    "target_ref",
    "owner_skill",
    "reviewer",
    "adoption_report_ref",
    "federation_ref",
    "agents_ref",
    "hooks_refs",
    "checks",
    "verdict",
    "integration_allowed",
    "findings",
    "next_actions",
    "canonical_write_allowed"
  ],
  "properties": {
    "schema_version": { "type": "string", "minLength": 1 },
    "id": { "type": "string", "minLength": 1 },
    "operation_id": { "type": "string", "const": "growgraph.integration-review" },
    "created_at": { "type": "string", "minLength": 1 },
    "target_ref": { "type": "string", "minLength": 1 },
    "owner_skill": { "type": "string", "minLength": 1 },
    "reviewer": { "type": "string", "minLength": 1 },
    "adoption_report_ref": { "type": ["string", "null"] },
    "federation_ref": { "type": ["string", "null"] },
    "agents_ref": { "type": ["string", "null"] },
    "hooks_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "checks": {
      "type": "object",
      "required": [
        "agents_routing_reviewed",
        "agents_owner_boundary_preserved",
        "agents_no_duplication_preserved",
        "hooks_contract_reviewed",
        "hooks_validate_contracts",
        "hooks_block_unsafe_canonical_write",
        "hooks_do_not_force_runtime"
      ],
      "properties": {
        "agents_routing_reviewed": { "$ref": "#/$defs/check" },
        "agents_owner_boundary_preserved": { "$ref": "#/$defs/check" },
        "agents_no_duplication_preserved": { "$ref": "#/$defs/check" },
        "hooks_contract_reviewed": { "$ref": "#/$defs/check" },
        "hooks_validate_contracts": { "$ref": "#/$defs/check" },
        "hooks_block_unsafe_canonical_write": { "$ref": "#/$defs/check" },
        "hooks_do_not_force_runtime": { "$ref": "#/$defs/check" }
      },
      "additionalProperties": true
    },
    "verdict": {
      "type": "string",
      "enum": [
        "pass",
        "pass_with_notes",
        "blocked_missing_agents",
        "blocked_missing_hooks",
        "blocked_integration_risk"
      ]
    },
    "integration_allowed": { "type": "boolean" },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "check", "summary", "required_action"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["info", "minor", "major", "blocker"]
          },
          "check": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "minLength": 1 },
          "evidence_refs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "required_action": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": true
      }
    },
    "next_actions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "canonical_write_allowed": { "const": false }
  },
  "$defs": {
    "check": {
      "type": "string",
      "enum": ["pass", "fail", "unknown", "not_applicable"]
    }
  },
  "additionalProperties": true
}
