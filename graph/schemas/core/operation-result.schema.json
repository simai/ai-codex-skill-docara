{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://simai.io/schemas/graph/operation-result.schema.json",
  "title": "OperationResult",
  "type": "object",
  "required": [
    "operation_id",
    "status",
    "mode",
    "changed_canonical_objects",
    "changed_generated_artifacts",
    "warnings",
    "next_suggested_operations"
  ],
  "properties": {
    "operation_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "success",
        "partial",
        "blocked",
        "failed",
        "dry_run"
      ]
    },
    "mode": {
      "type": "string"
    },
    "changed_canonical_objects": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "changed_generated_artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created_drafts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_status": {
      "type": "string"
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rollback_ref": {
      "type": "string"
    },
    "retention_class": {
      "type": "string"
    },
    "next_suggested_operations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
