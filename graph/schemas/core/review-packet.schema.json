{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://simai.io/schemas/graph/review-packet.schema.json",
  "title": "ReviewPacket",
  "type": "object",
  "required": [
    "id",
    "schema_version",
    "created_at",
    "operation_id",
    "status",
    "source_inventory",
    "scope_proposal",
    "dna_candidates",
    "object_candidates",
    "relation_candidates",
    "missing_questions",
    "acceptance_checklist",
    "next_suggested_operations"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "operation_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "ready_for_review",
        "partially_accepted",
        "accepted",
        "rejected",
        "superseded"
      ]
    },
    "source_inventory": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/source"
      }
    },
    "scope_proposal": {
      "type": "object",
      "required": [
        "title",
        "summary"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "depth_mode": {
          "type": "string",
          "enum": [
            "light",
            "standard",
            "full"
          ]
        },
        "owner_skill": {
          "type": "string"
        },
        "parent_dna_ref": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "dna_candidates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/candidate"
      }
    },
    "object_candidates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/candidate"
      }
    },
    "relation_candidates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/candidate"
      }
    },
    "missing_questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risk_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptance_checklist": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/check"
      }
    },
    "next_suggested_operations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "required": [
        "source_ref",
        "source_type",
        "privacy_class"
      ],
      "properties": {
        "source_ref": {
          "type": "string"
        },
        "source_type": {
          "type": "string"
        },
        "privacy_class": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "candidate": {
      "type": "object",
      "required": [
        "candidate_id",
        "candidate_type",
        "title",
        "summary",
        "source_refs",
        "confidence",
        "evidence_status",
        "review_status"
      ],
      "properties": {
        "candidate_id": {
          "type": "string"
        },
        "candidate_type": {
          "type": "string",
          "enum": [
            "dna",
            "object",
            "relation"
          ]
        },
        "proposed_kind": {
          "type": "string"
        },
        "proposed_subtype": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "source_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "evidence_status": {
          "type": "string"
        },
        "review_status": {
          "type": "string",
          "enum": [
            "pending",
            "accepted",
            "rejected",
            "deferred",
            "needs_question"
          ]
        },
        "review_action": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "accept",
            "reject",
            "rename",
            "merge",
            "split",
            "defer",
            "needs_question",
            null
          ]
        },
        "review_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "check": {
      "type": "object",
      "required": [
        "id",
        "title",
        "status"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "pass",
            "partial",
            "missing",
            "blocked"
          ]
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
