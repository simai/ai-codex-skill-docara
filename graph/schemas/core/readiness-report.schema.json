{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://simai.io/schemas/graph/readiness-report.schema.json",
  "title": "ReadinessReport",
  "type": "object",
  "required": [
    "schema_version",
    "operation_id",
    "readiness_id",
    "created_at",
    "graph_id",
    "canonical_state_ref",
    "verdict",
    "validation",
    "stale_check",
    "contracts",
    "benchmarks",
    "packages",
    "federation",
    "warnings",
    "blockers",
    "canonical_write_allowed"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "operation_id": { "const": "graph.readiness" },
    "readiness_id": { "type": "string" },
    "created_at": { "type": "string" },
    "graph_id": { "type": "string" },
    "canonical_state_ref": { "type": "string" },
    "verdict": { "enum": ["ready_for_external_pilot", "not_ready"] },
    "validation": { "type": "object", "additionalProperties": true },
    "stale_check": { "type": "object", "additionalProperties": true },
    "contracts": { "type": "object", "additionalProperties": true },
    "benchmarks": { "type": "object", "additionalProperties": true },
    "packages": { "type": "object", "additionalProperties": true },
    "federation": { "type": "object", "additionalProperties": true },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "blockers": { "type": "array", "items": { "type": "string" } },
    "next_suggested_operations": { "type": "array", "items": { "type": "string" } },
    "canonical_write_allowed": { "const": false }
  },
  "additionalProperties": true
}
