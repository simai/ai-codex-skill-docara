{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://simai.io/schemas/graph/source-of-truth-context-comparison.schema.json",
  "title": "Mirai Graph Source Of Truth Context Comparison",
  "description": "Comparison between a graph-first context pack and raw skill sources before GGA10 apply dry-run.",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "operation_id",
    "created_at",
    "target_ref",
    "owner_skill",
    "context_pack_ref",
    "raw_source_refs",
    "verdict",
    "safe_scope_verdict",
    "full_source_replacement_verdict",
    "covered_capabilities",
    "missing_capabilities",
    "preserved_rules",
    "missing_rules",
    "blockers",
    "next_actions",
    "canonical_write_allowed"
  ],
  "properties": {
    "schema_version": { "type": "string", "minLength": 1 },
    "id": { "type": "string", "minLength": 1 },
    "operation_id": { "type": "string", "const": "mirai_graph.source-of-truth-context-comparison" },
    "created_at": { "type": "string", "minLength": 1 },
    "target_ref": { "type": "string", "minLength": 1 },
    "owner_skill": { "type": "string", "minLength": 1 },
    "context_pack_ref": { "type": "string", "minLength": 1 },
    "raw_source_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "verdict": {
      "type": "string",
      "enum": ["pass_narrow_scope", "blocked_semantic_loss", "blocked_missing_coverage", "insufficient_evidence"]
    },
    "safe_scope_verdict": { "type": "string", "minLength": 1 },
    "full_source_replacement_verdict": { "type": "string", "minLength": 1 },
    "covered_capabilities": {
      "type": "array",
      "items": { "$ref": "#/$defs/capability_row" }
    },
    "missing_capabilities": {
      "type": "array",
      "items": { "$ref": "#/$defs/capability_row" }
    },
    "preserved_rules": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "missing_rules": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "blockers": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "next_actions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "canonical_write_allowed": { "const": false }
  },
  "$defs": {
    "capability_row": {
      "type": "object",
      "required": ["id", "summary", "source_refs"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "source_refs": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
