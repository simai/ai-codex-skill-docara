  "title": "Business Process TZ Profile",
  "summary": "Domain profile for graph-based specifications of business processes, roles, steps, decisions, events, controls and evidence.",
  "extends": [
    "profile.universal_tz_core"
  ],
  "required_tz_roles": [
    "system",
    "component",
    "feature",
    "requirement",
    "constraint",
    "acceptance",
    "evidence"
  ],
  "optional_tz_roles": [
    "contract",
    "decision",
    "adoption",
    "risk",
    "open_question",
    "roadmap_item",
    "implementation_batch",
    "generated_doc"
  ],
  "allowed_relation_types": [
    "contains",
    "depends_on",
    "blocks",
    "implements",
    "documents",
    "tests",
    "constrains",
    "extends",
    "replaces",
    "conflicts_with",
    "uses",
    "affects",
    "requires_adoption_in",
    "is_projection_of",
    "is_generated_from"
  ],
  "required_contracts": [
    "role_boundary",
    "input_output",
    "approval",
    "audit",
    "handoff",
    "exception_handling"
